# Copy these values into the OpenClaw config on the Lightsail instance.
# Keep the real file out of git and do not paste live tokens into chat.

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token

# Model provider credentials. Use the provider already configured for your OpenClaw install.
OPENAI_API_KEY=replace_if_using_openai
ANTHROPIC_API_KEY=replace_if_using_anthropic

# Recommended Telegram access stance:
# pairing = unknown DMs get a pairing code; you approve them manually.
# open = public DMs are accepted. Avoid this unless you intentionally want it.
OPENCLAW_TELEGRAM_DM_POLICY=pairing

# Optional: pin allowed Telegram user/chat IDs after pairing.
OPENCLAW_TELEGRAM_ALLOW_FROM=

