TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token

# Preferred: send Telegram messages to the AWS/OpenCloud/LiveSailing agent.
AGENT_API_URL=https://your-agent-host.example.com/chat
AGENT_API_KEY=replace_with_your_agent_api_key
AGENT_API_AUTH_HEADER=Authorization
AGENT_API_AUTH_SCHEME=Bearer
AGENT_TIMEOUT_MS=30000

# Optional fallback if AGENT_API_URL is empty.
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-5.2

# Runtime mode:
# - polling is easiest for EC2/ECS/long-running processes.
# - webhook is better for public HTTPS hosting.
TELEGRAM_MODE=polling
PORT=3000
TELEGRAM_WEBHOOK_URL=https://your-public-host.example.com/telegram/webhook
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret

